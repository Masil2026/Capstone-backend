{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "k6 Load — 부하 생성기 지표 (B)",
  "uid": "k6-load",
  "tags": ["loadtest", "k6"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "현재 VUs",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_vus",
          "legendFormat": "VUs"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "처리량 (req/s) — 클라이언트 관측",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (rate(k6_http_reqs_total[30s]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "http_req_duration p95 / p99 (ms)",
      "description": "k6 실행 시 K6_PROMETHEUS_RW_TREND_STATS=\"p(90),p(95),p(99)\" 필요",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_http_req_duration_p99",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "에러율 (http_req_failed)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.01 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_http_req_failed_rate",
          "legendFormat": "failed rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "네트워크 송수신 (bytes/s)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_data_received_total[30s])",
          "legendFormat": "received"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_data_sent_total[30s])",
          "legendFormat": "sent"
        }
      ]
    }
  ]
}
