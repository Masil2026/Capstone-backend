{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "Spring Backend — 서버 내부 지표 (A)",
  "uid": "spring-backend",
  "tags": ["loadtest", "spring"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "요청 처리량 (req/s) — URI별",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"capstone-backend\"}[1m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "지연 p95 / p99 (전체)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"capstone-backend\"}[1m])))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"capstone-backend\"}[1m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "에러율 (5xx 비중)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.01 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"capstone-backend\",status=~\"5..\"}[1m])) / clamp_min(sum(rate(http_server_requests_seconds_count{application=\"capstone-backend\"}[1m])), 1)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU 사용률",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage{application=\"capstone-backend\"}",
          "legendFormat": "process"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "system_cpu_usage{application=\"capstone-backend\"}",
          "legendFormat": "system"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC pause (초/초)",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (action) (rate(jvm_gc_pause_seconds_sum{application=\"capstone-backend\"}[1m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap 사용량",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{application=\"capstone-backend\",area=\"heap\"})",
          "legendFormat": "heap used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_committed_bytes{application=\"capstone-backend\",area=\"heap\"})",
          "legendFormat": "heap committed"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "R2DBC 커넥션 풀 (max-size=20)",
      "description": "지표가 비면 백엔드에서 curl /actuator/prometheus | grep r2dbc 로 실제 메트릭명 확인",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "r2dbc_pool_acquired_connections{application=\"capstone-backend\"}",
          "legendFormat": "acquired (사용중)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "r2dbc_pool_pending_connections{application=\"capstone-backend\"}",
          "legendFormat": "pending (대기)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "r2dbc_pool_max_allocated_connections{application=\"capstone-backend\"}",
          "legendFormat": "max allocated"
        }
      ]
    }
  ]
}
